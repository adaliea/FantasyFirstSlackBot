# ── Required ──────────────────────────────────────────────────────────────────

# Slack app credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# The Blue Alliance API key (https://www.thebluealliance.com/account)
TBA_API_KEY=your-tba-api-key

# PostgreSQL (set by docker-compose automatically; override here for external DB)
DATABASE_URL=postgresql://fantasyfirst:fantasyfirst@localhost:5432/fantasyfirst

# ── Optional ─────────────────────────────────────────────────────────────────

# Slack user ID of the bot administrator (can run /debug all and manage any game)
ADMIN_USER_ID=U05L2LK6GCX

# Port the HTTP server listens on (default: 3000)
PORT=3000

# Password for the postgres container (default: fantasyfirst)
POSTGRES_PASSWORD=fantasyfirst

# ── Multi-workspace OAuth (leave blank for single-workspace mode) ─────────────
# SLACK_CLIENT_ID=your-client-id
# SLACK_CLIENT_SECRET=your-client-secret
# SLACK_STATE_SECRET=some-random-secret

# Public URL for live scoring links (include protocol, no trailing slash)
# Leave blank to disable scoring links in Slack messages (local dev mode)
# PUBLIC_URL=https://your-bot-host.example.com
